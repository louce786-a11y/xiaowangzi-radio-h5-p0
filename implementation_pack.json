  "motion_group": {
    "state_machine": [
      "loading",
      "catalog_idle",
      "catalog_auto_cycle",
      "catalog_drag",
      "draw_pending",
      "flattening",
      "rolling",
      "winning_reveal",
      "result_popup",
      "recovering"
    ],
    "catalog": {
      "initial_auto_cycle_delay_ms": 2000,
      "auto_cycle_interval_ms": 2000,
      "cycle_duration_ms": 360,
      "cycle_direction": "left",
      "cycle_easing": "sine-in-out",
      "manual_swipe": {
        "enabled": true,
        "threshold_px": 49,
        "drag_feedback_factor": 0.28,
        "drag_feedback_clamp_px": 42,
        "resume_auto_cycle_delay_ms": 4000
      }
    },
    "flatten_to_lane": {
      "duration_ms": 400,
      "easing": "cubic-out",
      "target_tier": "medium",
      "target_y": 38,
      "target_size": [
        139,
        217
      ],
      "post_hold_ms": 200
    },
    "roll": {
      "duration_ms": 6000,
      "step_px": 146,
      "roll_variants": [
        19,
        22,
        25
      ],
      "variant_selector": "round_id_hash_mod",
      "min_roll_count": 12,
      "pre_padding_count": 2,
      "tail_padding_count": 6,
      "easing": "quint-out",
      "css_cubic_bezier": "cubic-bezier(0.23, 1.0, 0.32, 1.0)",
      "sequence_build_policy": "repeat_catalog_order_and_replace_focus_index_with_server_result"
    },
    "focus_policy": {
      "single": "first_item",
      "multi": "highest_value_then_lowest_draw_index",
      "h5_must_not_decide_reward": true
    },
    "winning_reveal": {
      "highlight": true,
      "timeline": [
        {
          "property": "scale",
          "to": 1.08,
          "duration_ms": 160,
          "easing": "back-out"
        },
        {
          "property": "rotation",
          "to_deg": -4,
          "duration_ms": 80
        },
        {
          "property": "rotation",
          "to_deg": 3,
          "duration_ms": 80
        },
        {
          "property": "rotation",
          "to_deg": 0,
          "duration_ms": 80
        },
        {
          "property": "scale",
          "to": 0.74,
          "duration_ms": 180,
          "easing": "cubic-in"
        },
        {
          "property": "scale",
          "to": "rarity_final_scale",
          "duration_ms": 280,
          "easing": "back-out"
        }
      ],
      "rarity_final_scale": {
        "common": 1.18,
        "rare": 1.24,
        "legendary": 1.32
      }
    },
    "result_popup_orchestration": {
      "owned_by": "host_or_result_popup_component",
      "open_after_event": "roll_complete",
      "close_command": "close_result_popup",
      "after_close": [
        "reset_to_catalog",
        "unlock_input",
        "resume_auto_cycle"
      ]
    },
    "reduced_motion": {
      "mode": "optional",
      "catalog_auto_cycle": true,
      "roll_duration_ms": 1200,
      "winning_reveal": "scale_only"
    }
  },
